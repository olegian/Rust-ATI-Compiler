ppt bar:::ENTER
ppt-type enter
variable arr[..]
  comparability 8
variable arr_LEN
  comparability 11
variable unused
  comparability 12
variable y
  comparability 13
variable z
  comparability 14

ppt bar:::EXIT
ppt-type exit
variable RET
  comparability 8
variable arr[..]
  comparability 8
variable arr_LEN
  comparability 11
variable unused
  comparability 12
variable y
  comparability 14
variable z
  comparability 14

ppt foo:::ENTER
ppt-type enter
variable arr[..]
  comparability 0
variable arr_LEN
  comparability 1
variable unused
  comparability 4
variable x
  comparability 2
variable y
  comparability 3

ppt foo:::EXIT
ppt-type exit
variable RET
  comparability 3
variable arr[..]
  comparability 0
variable arr_LEN
  comparability 1
variable unused
  comparability 4
variable x
  comparability 3
variable y
  comparability 3

ppt main:::ENTER
ppt-type enter

ppt main:::EXIT
ppt-type exit

